{
  "topic": "series",
  "topic_name_zh": "无穷级数",
  "problems": [
    {
      "id": "SER-001",
      "difficulty": "easy",
      "difficulty_label_zh": "简单",
      "knowledge_points": ["几何级数", "级数求和"],
      "problem_statement": "判断级数 $\\sum_{n=1}^{\\infty} \\frac{2^n}{3^n}$ 是否收敛，若收敛求其和。",
      "solution": {
        "method": "识别为几何级数",
        "steps": [
          "$\\frac{2^n}{3^n} = (\\frac{2}{3})^n$，公比 $r = \\frac{2}{3}$",
          "$|r| = \\frac{2}{3} < 1$，所以几何级数收敛",
          "和 $= \\frac{\\text{首项}}{1 - r} = \\frac{2/3}{1 - 2/3} = \\frac{2/3}{1/3} = 2$"
        ],
        "final_answer": "收敛，和为 2"
      },
      "grading_rubric": {
        "key_steps": ["识别公比", "判断 |r| < 1", "用公式求级数和"],
        "common_errors": ["忘记检查 |r| < 1", "首项取错（n=1时 a₁=2/3）", "求和公式分母写错"]
      }
    },
    {
      "id": "SER-002",
      "difficulty": "medium",
      "difficulty_label_zh": "中等",
      "knowledge_points": ["比值判别法"],
      "problem_statement": "判断级数 $\\sum_{n=1}^{\\infty} \\frac{n!}{n^n}$ 的收敛性。",
      "solution": {
        "method": "比值判别法（达朗贝尔判别法）",
        "steps": [
          "$a_n = \\frac{n!}{n^n}$",
          "$\\frac{a_{n+1}}{a_n} = \\frac{(n+1)!}{(n+1)^{n+1}} \\cdot \\frac{n^n}{n!} = \\frac{n+1}{(n+1)^{n+1}} \\cdot n^n = \\frac{n^n}{(n+1)^n}$",
          "$= \\left(\\frac{n}{n+1}\\right)^n = \\left(1 - \\frac{1}{n+1}\\right)^n$",
          "$\\lim_{n\\to\\infty} \\frac{a_{n+1}}{a_n} = \\lim_{n\\to\\infty} \\left(1 - \\frac{1}{n+1}\\right)^n = e^{-1} = \\frac{1}{e}$",
          "$\\frac{1}{e} < 1$，由比值判别法知级数收敛。"
        ],
        "final_answer": "级数收敛"
      },
      "grading_rubric": {
        "key_steps": ["写出比值 a_{n+1}/a_n", "化简比值", "求极限", "与 1 比较得出结论"],
        "common_errors": ["比值化简错误", "极限计算错误", "忘记需要与 1 比较"]
      }
    },
    {
      "id": "SER-003",
      "difficulty": "medium",
      "difficulty_label_zh": "中等",
      "knowledge_points": ["幂级数", "收敛半径"],
      "problem_statement": "求幂级数 $\\sum_{n=1}^{\\infty} \\frac{x^n}{n}$ 的收敛域。",
      "solution": {
        "method": "求收敛半径 + 检查端点",
        "steps": [
          "$a_n = \\frac{1}{n}$，收敛半径 $R = \\lim_{n\\to\\infty} |\\frac{a_n}{a_{n+1}}| = \\lim_{n\\to\\infty} \\frac{n+1}{n} = 1$",
          "在 $x = 1$：级数变为 $\\sum \\frac{1}{n}$（调和级数），发散",
          "在 $x = -1$：级数变为 $\\sum \\frac{(-1)^n}{n}$（交错调和级数），由莱布尼兹判别法，收敛",
          "所以收敛域为 $[-1, 1)$"
        ],
        "final_answer": "[-1, 1)"
      },
      "grading_rubric": {
        "key_steps": ["用公式求收敛半径", "检查左端点 x=-1", "检查右端点 x=1", "写出收敛域"],
        "common_errors": ["只求收敛半径不检查端点", "端点判断错误", "区间表示不准确"]
      }
    },
    {
      "id": "SER-004",
      "difficulty": "hard",
      "difficulty_label_zh": "困难",
      "knowledge_points": ["傅里叶级数"],
      "problem_statement": "求 $f(x) = |x|$ （$-\\pi < x < \\pi$）的傅里叶级数展开式。",
      "solution": {
        "method": "傅里叶系数公式（偶延拓）",
        "steps": [
          "$f(x) = |x|$ 是偶函数，所以 $b_n = 0$（只有余弦级数）",
          "$a_0 = \\frac{1}{\\pi}\\int_{-\\pi}^{\\pi} |x|\\,dx = \\frac{2}{\\pi}\\int_0^{\\pi} x\\,dx = \\frac{2}{\\pi} \\cdot \\frac{\\pi^2}{2} = \\pi$",
          "$a_n = \\frac{1}{\\pi}\\int_{-\\pi}^{\\pi} |x|\\cos(nx)\\,dx = \\frac{2}{\\pi}\\int_0^{\\pi} x\\cos(nx)\\,dx$",
          "分部积分：$\\int x\\cos(nx)dx = \\frac{x\\sin(nx)}{n} + \\frac{\\cos(nx)}{n^2}$",
          "$a_n = \\frac{2}{\\pi}[\\frac{x\\sin(nx)}{n} + \\frac{\\cos(nx)}{n^2}]_0^{\\pi} = \\frac{2}{\\pi}(\\frac{\\cos(n\\pi)-1}{n^2}) = \\frac{2((-1)^n-1)}{\\pi n^2}$",
          "$a_n = 0$（$n$ 偶），$a_n = -\\frac{4}{\\pi n^2}$（$n$ 奇）",
          "$f(x) = \\frac{\\pi}{2} + \\sum_{k=1}^{\\infty} \\frac{-4}{\\pi(2k-1)^2} \\cos((2k-1)x)$"
        ],
        "final_answer": "f(x) = \\frac{\\pi}{2} - \\frac{4}{\\pi}\\sum_{k=1}^{\\infty}\\frac{\\cos((2k-1)x)}{(2k-1)^2}"
      },
      "grading_rubric": {
        "key_steps": ["识别偶函数 → b_n = 0", "计算 a₀", "用分部积分计算 a_n", "化简并写出最终级数"],
        "common_errors": ["a₀ 忘记除 2（即 a_0/2 的写法）", "分部积分出错", "(-1)^n 的化简错误", "忘记只保留奇数项"]
      }
    },
    {
      "id": "SER-005",
      "difficulty": "hard",
      "difficulty_label_zh": "困难",
      "knowledge_points": ["比较判别法", "极限形式"],
      "problem_statement": "判断级数 $\\sum_{n=2}^{\\infty} \\frac{1}{n \\ln n}$ 是否收敛。",
      "solution": {
        "method": "积分判别法",
        "steps": [
          "令 $f(x) = \\frac{1}{x \\ln x}$，$f(x)$ 在 $[2, +\\infty)$ 上非负单调递减",
          "$\\int_2^{+\\infty} \\frac{1}{x\\ln x}\\,dx$：令 $u = \\ln x, du = \\frac{dx}{x}$",
          "$= \\int_{\\ln 2}^{+\\infty} \\frac{1}{u}\\,du = [\\ln|u|]_{\\ln 2}^{+\\infty} = +\\infty$（发散）",
          "由积分判别法，级数 $\\sum \\frac{1}{n\\ln n}$ 发散。"
        ],
        "final_answer": "发散"
      },
      "grading_rubric": {
        "key_steps": ["选择合适的判别法", "正确使用换元计算反常积分", "由积分结果判断级数收敛性"],
        "common_errors": ["误以为 1/(n ln n) 收敛（和 p-级数混淆）", "积分判别法使用条件不满足", "反常积分计算出错"]
      }
    },
    {
      "id": "SER-006",
      "difficulty": "medium",
      "difficulty_label_zh": "中等",
      "knowledge_points": ["幂级数求和", "逐项求导"],
      "problem_statement": "求幂级数 $\\sum_{n=1}^{\\infty} n x^{n-1}$ 的和函数（$|x| < 1$）。",
      "solution": {
        "method": "利用几何级数逐项求导",
        "steps": [
          "已知 $\\sum_{n=0}^{\\infty} x^n = \\frac{1}{1-x}$（$|x|<1$）",
          "两边对 $x$ 求导：$\\sum_{n=1}^{\\infty} n x^{n-1} = \\frac{d}{dx}\\left(\\frac{1}{1-x}\\right) = \\frac{1}{(1-x)^2}$",
          "所以和函数为 $S(x) = \\frac{1}{(1-x)^2}$（$|x| < 1$）"
        ],
        "final_answer": "\\frac{1}{(1-x)^2} \\quad (|x| < 1)"
      },
      "grading_rubric": {
        "key_steps": ["利用几何级数作为出发点", "逐项求导", "化简导函数", "标明收敛域"],
        "common_errors": ["n 的起始值搞错", "忘记逐项求导的合法性需要 |x|<1", "导数公式算错"]
      }
    }
  ]
}
