# MathLearnLab 环境变量示例
# 复制此文件为 .env 并填入实际值，不要将 .env 提交到 Git

# ── 调试模式 ──
# 开发环境设为 true，生产环境必须为 false
DEBUG=false

# ── JWT 签名密钥（生产环境必填） ──
# 使用 python -c "import secrets; print(secrets.token_urlsafe(32))" 生成
# 生产环境未设置时将拒绝启动
JWT_SECRET_KEY=

# ── 管理员密钥（用于 /admin 页面登录） ──
# 建议与 JWT_SECRET_KEY 同样长度，不要使用默认值
ADMIN_SECRET=

# ── AI Provider：DeepSeek ──
# DeepSeek API Key（OpenAI 兼容端点）
DEEPSEEK_API_KEY=

# ── 默认模型 ──
# 可选：deepseek-chat, deepseek-reasoner
DEEPSEEK_MODEL=deepseek-chat

# ── 数据库 ──
# 留空则使用 SQLite；MySQL 格式：mysql://user:password@host/dbname
DATABASE_URL=mysql://mathlab:MathLab2024_@localhost/mathlearnlab

# ── 邮件通知（用户注册审核） ──
SMTP_HOST=smtp.163.com
SMTP_USER=
SMTP_PASS=
ADMIN_EMAIL=

# ── 内容路径 ──
CONTENT_DIR=content
DATA_DIR=data
